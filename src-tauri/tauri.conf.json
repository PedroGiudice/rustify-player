{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rustify-player",
  "version": "0.1.0",
  "identifier": "dev.cmr.rustifyplayer",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "rustify-player",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "theme": "Dark",
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval'; img-src 'self' asset: http://asset.localhost data:; connect-src 'self' ipc: http://ipc.localhost; font-src 'self' data:",
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/.cache/rustify-player/**", "**/.cache/rustify-player/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libpipewire-0.3-0", "policykit-1", "jq", "gh"],
        "files": {
          "/usr/bin/rustify-update": "../scripts/rustify-update.sh",
          "/usr/share/rustify-player/VERSION": "build-metadata/VERSION"
        }
      }
    }
  }
}
